# ── LLM ──────────────────────────────────────────────────────────
LLM_PROVIDER=openai                   # openai | anthropic
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
EMBEDDINGS_PROVIDER=openai

# ── Vector store (Qdrant Cloud) ───────────────────────────────────
QDRANT_URL=https://xxx.qdrant.io
QDRANT_API_KEY=...
QDRANT_COLLECTION=adaptive_tutor

# ── Relational DB (Supabase) ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ── Cache (Upstash Redis) ─────────────────────────────────────────
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=...

# ── Web fallback (Chunk 6) ────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Auth (Chunk 9) ────────────────────────────────────────────────
JWT_SECRET=change-this-in-production

# ── App ───────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Chunk 5 — Reranking ───────────────────────────────────────────
RERANKER_BACKEND=bge                  # bge | voyage
RERANKER_MODEL=BAAI/bge-reranker-base
RERANK_TOP_N=5
RERANK_CANDIDATE_K=20
HYDE_NUM_HYPOTHETICALS=3

# ── Chunk 6 — CRAG ───────────────────────────────────────────────
CRAG_RELEVANCE_THRESHOLD=0.7
CRAG_TRUSTED_DOMAINS=khanacademy.org,wikipedia.org,britannica.com

# ── Chunk 7 — Self-RAG ───────────────────────────────────────────
REFLECTION_MIN_SCORE=0.8
REFLECTION_MAX_RETRIES=2
MASTERY_BYPASS_THRESHOLD=0.85
